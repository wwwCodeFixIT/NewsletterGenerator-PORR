{
  "name": "porr-newsletter-generator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "cf:dev": "npm run build && npx wrangler pages dev dist --local",
    "db:create": "npx wrangler d1 create porr-newsletter-generator",
    "db:migrate:local": "npx wrangler d1 migrations apply porr-newsletter-generator --local",
    "db:migrate:remote": "npx wrangler d1 migrations apply porr-newsletter-generator --remote"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "^22.0.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "7.2.4",
    "vite-plugin-singlefile": "2.3.0"
  }
}
